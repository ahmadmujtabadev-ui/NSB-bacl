# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/noorstudio

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ── AI Text Provider ──────────────────────────────────────────────────────────
# Options: claude | mock
AI_TEXT_PROVIDER=claude
CLAUDE_API_KEY=

# ── AI Image Provider ─────────────────────────────────────────────────────────
# BFL FLUX — text-to-image (anchor + cover + portrait)
BFL_API_KEY=

# Replicate — img2img with character consistency (illustration chapters 2–N)
REPLICATE_API_TOKEN=

# Google Gemini — pose sheet generation ONLY
GOOGLE_API_KEY=

# NanoBanana — optional fallback
NANOBANANA_API_KEY=
NANOBANANA_API_URL=https://api.nanobanana.com/v1
NANOBANANA_MODEL=pixar-3d-v1

# ── AI Tuning ────────────────────────────────────────────────────────────────
AI_MAX_RETRIES=2

# ── Vercel Puppeteer PDF Export ──────────────────────────────────────────────
# Optional. Defaults to Sparticuz Chromium v147 x64 pack if unset.
CHROMIUM_REMOTE_EXEC_PATH=https://github.com/Sparticuz/chromium/releases/download/v147.0.0/chromium-v147.0.0-pack.x64.tar

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# ── Cloudinary (for image CDN uploads) ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Railway (for absolute URL resolution) ────────────────────────────────────
RAILWAY_PUBLIC_DOMAIN=
PUBLIC_URL=

# ── Credits ───────────────────────────────────────────────────────────────────
NEW_USER_CREDIT_BONUS=50
